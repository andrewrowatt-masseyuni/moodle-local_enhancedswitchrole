{{!
    @template local_enhancedswitchrole/roles

    Displays role switching buttons with optional group selection for student roles.

    Example context (json):
    {
        "url": "https://example.com/local/enhancedswitchrole/switchrole.php",
        "groups": [
            {
                "groupname": "Group A",
                "groupid": 1
            },
            {
                "groupname": "Group B",
                "groupid": 2
            }
        ],
        "roles": [
            {
                "id": 123,
                "switchrole": 5,
                "returnurl": "https://example.com/course/view.php?id=123",
                "role": "Student",
                "sesskey": "abcd1234",
                "hasgroups": true
            },
            {
                "id": 123,
                "switchrole": 0,
                "returnurl": "https://example.com/course/view.php?id=123",
                "role": "Return to my normal role",
                "sesskey": "abcd1234"
            }
        ]
    }
}}
{{#roles}}
<div class="mx-3 mb-1"{{#hasgroups}} style="display: flex; gap: 0.25em;"{{/hasgroups}}>
    <div class="singlebutton">
        <form method="post" action="{{url}}">
                <input type="hidden" name="id" value="{{id}}">
                <input type="hidden" name="switchrole" value="{{switchrole}}">
                <input type="hidden" name="returnurl" value="{{returnurl}}">
                <input type="hidden" name="sesskey" value="{{sesskey}}">
            <button type="submit" class="btn btn-secondary">{{role}}</button>
        </form>
    </div>
    {{#hasgroups}}
        <div>
            <div class="dropdown">
                <button class="btn btn-secondary dropdown-toggle" type="button" id="role-{{switchrole}}-group-selection" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                    {{#str}} studentingroup, local_enhancedswitchrole, {{role}}{{/str}}
                </button>
                <div class="dropdown-menu" aria-labelledby="role-{{switchrole}}-group-selection">
                    {{#groups}}
                    <a class="dropdown-item" href="{{url}}?id={{id}}&switchrole={{switchrole}}&returnurl={{returnurl}}&sesskey={{sesskey}}&groupid={{groupid}}"><i class="fa-solid fa-user-group"></i> {{groupname}}</a>
                    {{/groups}}
                </div>
            </div>
        </div>
    {{/hasgroups}}
</div>
{{/roles}}