{{!
    @template local_enhancedswitchrole/role_with_group_dropdown

    TODO describe template role_with_group_dropdown

    Example context (json):
    {
        "rolebutton": "<button class=\"btn btn-secondary\">Switch role</button>",
        "dropdownid": "groupDropdown3",
        "dropdownlabel": "Student in group",
        "groups": [
            {
                "groupname": "Group A",
                "groupurl": "https://moodle.example.com/local/enhancedswitchrole/switchrole.php?id=2&switchrole=3&groupid=5&returnurl=https%3A%2F%2Fmoodle.example.com%2Fcourse%2Fview.php%3Fid%3D2&sesskey=abc123"
            },
            {
                "groupname": "Group B",
                "groupurl": "https://moodle.example.com/local/enhancedswitchrole/switchrole.php?id=2&switchrole=3&groupid=6&returnurl=https%3A%2F%2Fmoodle.example.com%2Fcourse%2Fview.php%3Fid%3D2&sesskey=abc123"
            }
        ]
    }
}}
<div class="mx-3 mb-1" style="display: flex; gap: 0.25em;">
    {{{rolebutton}}}
    <div>
        <div class="dropdown">
            <button class="btn btn-secondary dropdown-toggle" type="button" id="{{dropdownid}}" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                {{dropdownlabel}}
            </button>
            <div class="dropdown-menu" aria-labelledby="{{dropdownid}}">
                {{#groups}}
                <a class="dropdown-item" href="{{groupurl}}"><i class="fa-solid fa-user-group"></i> {{groupname}}</a>
                {{/groups}}
            </div>
        </div>
    </div>
</div>
